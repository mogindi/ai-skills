{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Skills Manifest",
  "type": "object",
  "required": ["schema_version", "constraints", "defaults", "skills"],
  "properties": {
    "schema_version": {"const": 1},
    "constraints": {
      "type": "object",
      "required": ["allowed_statuses", "allowed_execution_backends", "allowed_permissions", "allowed_models"],
      "properties": {
        "allowed_statuses": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "allowed_execution_backends": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "allowed_permissions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "allowed_models": {"type": "array", "items": {"type": "string"}, "minItems": 1}
      },
      "additionalProperties": false
    },
    "defaults": {
      "type": "object",
      "required": ["source_repo", "source_ref"],
      "properties": {
        "source_repo": {"type": "string", "minLength": 1},
        "source_ref": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "skills": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "description",
          "status",
          "required_ad_group",
          "allowed_models",
          "approval_required",
          "execution_backend",
          "source_path",
          "version",
          "owner",
          "last_validated_at"
        ],
        "properties": {
          "description": {"type": "string", "minLength": 1},
          "status": {"type": "string"},
          "required_ad_group": {"type": "string"},
          "allowed_models": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "approval_required": {"type": "boolean"},
          "can_write_artifacts": {"type": "boolean"},
          "execution_backend": {"type": "string"},
          "source_repo": {"type": "string"},
          "source_path": {"type": "string", "pattern": "^skills/[a-z0-9]+(-[a-z0-9]+)*$"},
          "source_ref": {"type": "string"},
          "version": {"type": "string"},
          "owner": {"type": "string"},
          "last_validated_at": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
          "swarm": {
            "type": "object",
            "required": ["max_rounds", "acceptance_criteria", "roles"],
            "properties": {
              "max_rounds": {"type": "integer", "minimum": 1},
              "acceptance_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1},
              "roles": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "role", "phase"],
                  "properties": {
                    "id": {"type": "string", "minLength": 1},
                    "role": {"type": "string", "minLength": 1},
                    "phase": {"type": "string", "minLength": 1},
                    "blocking_rules": {"type": "array", "items": {"type": "string"}}
                  },
                  "additionalProperties": false
                },
                "minItems": 1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
